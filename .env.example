# Copy this file to .env and fill in your values before running bootstrap.sh
#
#   cp .env.example .env
#   nano .env          # or vim, code, etc.
#   bash bootstrap.sh

# 1Password service account token (required)
# Get it from: 1Password → Settings → Developer → Service Accounts
# Backup location: op://homelab/Service Account Auth Token: ansible/token
export OP_SERVICE_ACCOUNT_TOKEN=

# Optional overrides
# export HOMELAB_DIR=$HOME/homelab2
